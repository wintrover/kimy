; Sample .deps.nif file for testing
(dep "z3.solveConstraint" "import" "z3/Solver")
(dep "z3.solveConstraint" "import" "z3/Model")
(dep "z3.solveConstraint" "call" "z3.Solver.init")
(dep "z3.solveConstraint" "call" "z3.Model.validate")
(dep "z3.addConstraint" "import" "z3/Solver")
(dep "z3.addConstraint" "call" "z3.Solver.add")
(dep "z3.withSolver" "include" "z3/internal_utils.nim")
(dep "z3.withSolver" "include" "z3/types_common.nim")
(dep "z3.Constraint" "type-ref" "z3.Expr")
(dep "z3.Solver" "import" "z3/Context")
(import "z3" "Constraint" "Solver" "Model")
(include "z3/internal_utils.nim")
(include "z3/types_common.nim")
